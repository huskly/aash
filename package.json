{
  "name": "aave-loan-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "yarn tsc --noEmit -p tsconfig.app.json && yarn tsc --noEmit -p tsconfig.node.json && yarn workspace @aave-monitor/core typecheck && yarn workspace @aave-monitor/server typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:server": "yarn workspace @aave-monitor/server dev",
    "dev:all": "yarn dev & yarn dev:server",
    "build:server": "yarn workspace @aave-monitor/server build",
    "morpho:market-env": "yarn workspace @aave-monitor/server morpho:market-env",
    "test": "yarn workspace @aave-monitor/server test",
    "test:contracts": "forge test --root packages/rescue-contract",
    "deploy:rescue:dry-run": "forge script script/DeployAaveAtomicRepayV1.s.sol --root packages/rescue-contract"
  },
  "dependencies": {
    "@aave-monitor/core": "*",
    "@radix-ui/react-slider": "^1.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.5"
  }
}
