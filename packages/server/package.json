{
  "name": "@aave-monitor/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsx --tsconfig tsconfig.test.json --test test/**/*.test.ts",
    "morpho:market-env": "tsx src/scripts/morphoMarketEnv.ts",
    "dev": "node --import tsx --watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aave-monitor/core": "*",
    "@bgd-labs/aave-address-book": "^4.44.22",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2"
  }
}
